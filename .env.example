# Optional tuning
GEMINI_MODEL=gemini-2.5-flash
MAX_POSTS_PER_RUN=3
MIN_SCORE=25
RECENT_TITLES_HOURS=24
FEEDS_PATH=feeds.yaml
KEYWORDS_PATH=keywords.yaml
DRY_RUN=false
TEST_MODERATION_MODE=false
