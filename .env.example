DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
TELEGRAM_BOT_TOKEN=123456:ABC-your-token
TELEGRAM_CHANNEL_ID=@your_channel
TEST_TELEGRAM_TOKEN=123456:ABC-your-test-token
TEST_CHANNEL_ID=@your_test_channel
TEST_ADMIN_CHAT_ID=-1001234567890
GEMINI_API_KEY=AIzaSy...
OPENROUTER_API_KEY=sk-or-v1-...   # optional - enables fallback chain
GROQ_API_KEY=gsk_...
GH_MODELS_API_KEY=ghm_...
